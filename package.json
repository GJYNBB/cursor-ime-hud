{
  "name": "cursor-ime-hud",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.2",
  "publisher": "chestnut-ch",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GJYNBB/cursor-ime-hud.git"
  },
  "homepage": "https://github.com/GJYNBB/cursor-ime-hud#readme",
  "bugs": {
    "url": "https://github.com/GJYNBB/cursor-ime-hud/issues"
  },
  "files": [
    "out/*.js",
    "out/commands/**/*.js",
    "out/controller/**/*.js",
    "out/detector/**/*.js",
    "out/model/**/*.js",
    "out/presenters/**/*.js",
    "out/renderer/**/*.js",
    "out/services/**/*.js",
    "resources/icon.png",
    "resources/bin/win-x64/WinImeWatcher.exe",
    "resources/bin/win-x64/WinImeWatcher.exe.sha256",
    "resources/screenshots/**/*",
    "package.nls*.json",
    "README.md",
    "README.en.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE",
    "ARCHITECTURE.md",
    "CONTRIBUTING.md",
    "docs/helper-protocol.md",
    "SECURITY.md",
    "SUPPORT.md",
    "CODE_OF_CONDUCT.md"
  ],
  "engines": {
    "node": ">=24.0.0",
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "ime",
    "input method",
    "cursor",
    "hud",
    "windows",
    "wechat input"
  ],
  "extensionKind": [
    "ui"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": {
      "supported": true
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorImeHud.toggleOverlay",
        "title": "%commands.toggleOverlay.title%",
        "category": "%commands.category%"
      },
      {
        "command": "cursorImeHud.refreshImeState",
        "title": "%commands.refreshImeState.title%",
        "category": "%commands.category%"
      },
      {
        "command": "cursorImeHud.showDiagnostics",
        "title": "%commands.showDiagnostics.title%",
        "category": "%commands.category%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "cursorImeHud.overlay.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.overlay.enabled.description%"
        },
        "cursorImeHud.overlay.labelPreset": {
          "type": "string",
          "enum": [
            "custom",
            "zh-en",
            "en-zh"
          ],
          "enumDescriptions": [
            "%configuration.overlay.labelPreset.enum.custom%",
            "%configuration.overlay.labelPreset.enum.zhEn%",
            "%configuration.overlay.labelPreset.enum.enZh%"
          ],
          "default": "custom",
          "description": "%configuration.overlay.labelPreset.description%"
        },
        "cursorImeHud.overlay.cnLabel": {
          "type": "string",
          "default": "中",
          "description": "%configuration.overlay.cnLabel.description%"
        },
        "cursorImeHud.overlay.enLabel": {
          "type": "string",
          "default": "英",
          "description": "%configuration.overlay.enLabel.description%"
        },
        "cursorImeHud.overlay.opacity": {
          "type": "number",
          "default": 0.78,
          "minimum": 0.15,
          "maximum": 1,
          "description": "%configuration.overlay.opacity.description%"
        },
        "cursorImeHud.overlay.mode": {
          "type": "string",
          "enum": [
            "text",
            "text+icon"
          ],
          "default": "text",
          "markdownDescription": "%configuration.overlay.mode.markdownDescription%"
        },
        "cursorImeHud.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.statusBar.enabled.description%"
        },
        "cursorImeHud.overlay.hideWhenEditorUnfocused": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.overlay.hideWhenEditorUnfocused.description%"
        },
        "cursorImeHud.overlay.offsetX": {
          "type": "number",
          "default": 6,
          "minimum": 0,
          "maximum": 32,
          "description": "%configuration.overlay.offsetX.description%"
        },
        "cursorImeHud.overlay.offsetY": {
          "type": "number",
          "default": 0,
          "minimum": -16,
          "maximum": 16,
          "description": "%configuration.overlay.offsetY.description%"
        }
      }
    }
  },
  "scripts": {
    "clean": "powershell -ExecutionPolicy Bypass -File ./scripts/clean.ps1",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:helper": "powershell -ExecutionPolicy Bypass -File ./scripts/build-helper.ps1",
    "test:extension": "node ./scripts/run-extension-tests.js",
    "test:helper": "node ./scripts/assert-helper-once.js",
    "test:unit": "npm run compile && npm run test:extension",
    "test:integration": "npm run build:helper && npm run test:helper",
    "test": "npm run test:unit && npm run test:integration",
    "hash:helper": "node ./scripts/hash-helper.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "coverage": "c8 --reporter=text --reporter=lcov npm run test:extension",
    "vscode:prepublish": "node ./scripts/check-publisher.js && npm run compile && npm run build:helper",
    "package:vsix": "npx @vscode/vsce package",
    "prepublishOnly": "node ./scripts/check-publisher.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.2",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "mocha": "^11.7.6",
    "prettier": "^3.8.3",
    "sinon": "^22.0.0",
    "typescript": "^6.0.3"
  }
}
